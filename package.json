{
  "name": "hoeengbot-website",
  "version": "1.0.1",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "type-check": "tsc --noEmit",
    "build": "npm run type-check && npm run lint && vite build",
    "preview": "vite preview",
    "lint": "biome check src/main.ts src/style.css vite.config.ts",
    "format": "biome format --write src/main.ts src/style.css vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoehoetvhss/hoeengbot-website.git"
  },
  "author": "hoehoetvhs",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-ejs": "^1.7.0"
  }
}
